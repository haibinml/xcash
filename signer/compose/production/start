#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset

cd /app/signer

eval "$(python /app/performance.py shell-env signer)"

# signer 数据库迁移由 scripts/upgrade.sh 统一执行，避免容器启动时绕过迁移演练入口。

exec gunicorn config.wsgi:application \
  --bind 0.0.0.0:8000 \
  --chdir=/app/signer \
  --workers "${SIGNER_GUNICORN_WORKERS}"
